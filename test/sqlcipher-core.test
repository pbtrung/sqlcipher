# This file implements regression tests for SQLite library.  The
# focus of this script is testing code cipher features.
#
# NOTE: tester.tcl has overridden the definition of sqlite3 to
# automatically pass in a key value. Thus tests in this file
# should explicitly close and open db with sqlite_orig in order
# to bypass default key assignment.

set testdir [file dirname $argv0]
source $testdir/tester.tcl
source $testdir/sqlcipher.tcl

# The database is initially empty.
# set an hex key create some basic data
# create table and insert operations should work
# close database, open it again with the same
# hex key. verify that the table is readable
# and the data just inserted is visible
setup test.db "\"x''\""
do_test will-open-with-correct-raw-key {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    SELECT name FROM sqlite_schema WHERE type='table';
    SELECT * from t1;
  }
} {ok t1 test1 test2}
db close
file delete -force test.db

# PRAGMA key with the same raw key reopens correctly (this is a near-
# duplicate of will-open-with-correct-raw-key above by necessity: this
# provider has only one kind of key, so there is no longer a separate
# "derived from a passphrase" code path to distinguish it from).
setup test.db {"x''"}
do_test will-open-with-correct-derived-key {

  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    SELECT name FROM sqlite_schema WHERE type='table';
    SELECT * from t1;
  }
} {ok t1 test1 test2}
db close
file delete -force test.db

# compatibility textkey pragma
setup test.db {"x''"}
do_test will-open-with-correct-derived-textkey {

  sqlite_orig db test.db
  execsql {
    PRAGMA textkey = "x''";
    SELECT name FROM sqlite_schema WHERE type='table';
    SELECT * from t1;
  }
} {ok t1 test1 test2}
db close
file delete -force test.db

# PRAGMA hexkey decodes its hex argument straight into a *raw* key byte
# buffer (capped at 40 bytes by a fixed zBuf[40] in pragma.c, already well
# under our 256-byte minimum) and passes those bytes on unchanged -- it does
# not wrap them in the "x'...'" textual convention that
# sqlcipher_cipher_ctx_key_derive requires (see doc/crypto.md "Key
# provisioning" and src/sqlcipher.c sqlcipher_cipher_ctx_key_derive). With no
# more passphrase/PBKDF2 fallback to fall back on, PRAGMA hexkey (and the
# analogous "hexkey" URI parameter, which has its own separate 40-byte
# zDecoded buffer in src/main.c) can no longer reach a valid raw key at all,
# so it is effectively dead for this provider. Confirm that it fails
# clearly rather than silently.
setup test.db {"x''"}
do_test hexkey-pragma-no-longer-usable-for-raw-keys {
  sqlite_orig db test.db
  catchsql {
    PRAGMA hexkey = '746573746b6579';
    SELECT name FROM sqlite_schema WHERE type='table';
  }
} {1 {out of memory}}
db close
file delete -force test.db


# run test with the sqlite3_key() C API directly (bypassing PRAGMA parsing
# entirely) using a valid raw key -- confirms the raw-key convention is
# recognized identically regardless of which entry point supplies it.
setup test.db {"x''"}
do_test will-open-with-sqlite3key {

  sqlite_orig db test.db
  sqlite3_key db "x''"
  execsql {
    SELECT name FROM sqlite_schema WHERE type='table';
    SELECT * from t1;
  }
} {t1 test1 test2}
db close
file delete -force test.db

# demonstrate that sqlite3_key() with a short/passphrase-style value (the
# only kind of key the pre-migration AES/PBKDF2 codec accepted) is now
# rejected -- there is no passphrase support at all any more.
setup test.db {"x''"}
do_test sqlite3key-rejects-passphrase-style-key {
  sqlite_orig db test.db
  sqlite3_key db "testkey"
  catchsql {
    SELECT name FROM sqlite_schema WHERE type='table';
  }
} {1 {out of memory}}
db close
file delete -force test.db

# set an encryption key (non-hex) and create
# temp tables, verify you can read from
# sqlite_temp_master
setup test.db {"x''"}
do_test test-temp-master {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    CREATE TEMPORARY TABLE temp_t1(a,b);
    INSERT INTO temp_t1(a,b) VALUES ('test1', 'test2');
    SELECT name FROM sqlite_temp_master WHERE type='table';
    SELECT * from temp_t1;
  }
} {ok temp_t1 test1 test2}
db close
file delete -force test.db

# verify that a when a standard database is encrypted the first
# 16 bytes are not "SQLite format 3\0" 
do_test test-sqlcipher-header-overwrite {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    CREATE TABLE t1(a,b);
  }
  db close
  set header [hexio_read test.db 0 16]
  string equal $header "53514C69746520666F726D6174203300"
} {0}
file delete -force test.db

# open the database and try to read from it without
# providing a passphrase. verify that the 
# an error is returned from the library
setup test.db {"x''"}
do_test wont-open-without-key {
  sqlite_orig db test.db
  catchsql {
    SELECT name FROM sqlite_schema WHERE type='table';
  }
} {1 {file is not a database}}
db close
file delete -force test.db

# open the database and try to set an invalid
# passphrase. verify that an error is returned
# and that data couldn't be read
setup test.db {"x''"}
do_test wont-open-with-invalid-derived-key {
  sqlite_orig db test.db
  catchsql {
    PRAGMA key = "x''";
    SELECT name FROM sqlite_schema WHERE type='table';
  }
} {1 {file is not a database}}
db close
file delete -force test.db

# open the database and try to set an invalid
# hex key. verify that an error is returned
# and that data couldn't be read
setup test.db {"x''"}
do_test wont-open-with-invalid-raw-key {
  sqlite_orig db test.db
  catchsql {
    PRAGMA key = "x''";
    SELECT name FROM sqlite_schema WHERE type='table';
  }
} {1 {file is not a database}}
db close
file delete -force test.db

# test a large number of inserts in a transaction to a memory database 
do_test memory-database {
  sqlite_orig db :memory:
  execsql {
    PRAGMA key = "x''";
    BEGIN;
    CREATE TABLE t2(a,b);
  }
  for {set i 1} {$i<=25000} {incr i} {
    set r [expr {int(rand()*500000)}]
    execsql "INSERT INTO t2 VALUES($i,$r);" 
  }
  execsql {
    COMMIT;
    SELECT count(*) FROM t2;
    DELETE FROM t2;
    SELECT count(*) FROM t2;
  } 
} {25000 0}
db close

# test a large number of inserts in a transaction for multiple pages
do_test multi-page-database {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    CREATE TABLE t2(a,b);
    BEGIN;
  }
  for {set i 1} {$i<=25000} {incr i} {
    set r [expr {int(rand()*500000)}]
    execsql "INSERT INTO t2 VALUES($i,$r);" 
  }
  execsql {
    COMMIT;
    SELECT count(*) FROM t2;
  } 
} {25000}
db close
file delete -force test.db

# attach an encrypted database without specifying a key on the ATTACH
# clause, verify it fails when the attaching connection's own current key
# (which is what gets reused for a newly attached database lacking an
# explicit KEY clause) doesn't match the attached database's actual key.
#
# HISTORICAL NOTE: this test used to key both databases with the very same
# passphrase and rely on PBKDF2 deriving a different *actual* key per
# database (since each database has its own independently-random KDF
# salt), so that "the same passphrase" still produced a failed attach. That
# reasoning no longer applies: there is no passphrase/per-database-salt-
# derived master key any more (see doc/crypto.md) -- the raw master key
# supplied via PRAGMA key *is* the key, so two databases keyed with the
# identical raw key are trivially attachable without any KEY clause. To
# still demonstrate "attach without a key fails", the two databases here
# are deliberately keyed with two different raw keys.
setup test.db {"x''"}
do_test attach-database-with-default-key {
  sqlite_orig db2 test2.db
  set rc {}

  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher_add_random = "x'deadbaad'";
    CREATE TABLE t2(a,b);
    INSERT INTO t2 VALUES ('test1', 'test2');
  } db2

  lappend rc [catchsql {
    ATTACH 'test.db' AS db;
  } db2]

  lappend rc [string equal [hexio_read test.db 0 16] [hexio_read test2.db 0 16]]

} {{1 {file is not a database}} 0}
db2 close
file delete -force test.db
file delete -force test2.db

# attach an empty encrypted database without specifying key, and verify
# it is nonetheless readable with the same key as the main database (its
# key is inherited from the currently-attached connection since no KEY
# clause was given).
#
# HISTORICAL NOTE: this test used to also assert that the two databases'
# first 16 bytes (the plaintext KDF salt prefix in the old design) were
# EQUAL, on the theory that attach reused the already-derived salt for the
# newly created database. There is no plaintext salt prefix, no
# database-wide salt, and no salt "reuse" of any kind any more (see
# doc/crypto.md): every page, including page 1, gets a fresh independently-
# random salt on every single write, unconditionally. So the two databases'
# first 16 bytes (now ciphertext, not a plaintext salt) are expected to
# differ instead.
setup test.db {"x''"}
do_test attach-empty-database-with-default-key {
  sqlite_orig db test.db
  set rc {}

  execsql {
    PRAGMA  key="x''";
    INSERT INTO t1(a,b) values (1,2);
    ATTACH DATABASE 'test2.db' AS test;
    CREATE TABLE test.t1(a,b);
    INSERT INTO test.t1 SELECT * FROM t1;
    DETACH DATABASE test;
  }

  sqlite_orig db2 test2.db

  lappend rc [execsql {
    PRAGMA  key="x''";
    SELECT count(*) FROM t1;
  } db2]
  lappend rc [string equal [hexio_read test.db 0 16] [hexio_read test2.db 0 16]]
} {{ok 2} 0}
db close
db2 close
file delete -force test.db
file delete -force test2.db

# attach an empty encrypted database as the first operation on a keyed
# database. Verify it is readable with the same key as the main database.
#
# HISTORICAL NOTE: The original behavior of SQLCipher under these conditions
# was that the databases would have different salts but the same keys. This was because
# derivation of the key spec would not have occurred yet. However, upstream check-in
# https://sqlite.org/src/info/a02da71f3a80dd8e changed this behavior by
# forcing a read of the main database schema during the attach operation.
# This causes the main database to be opened and the key derivation logic to fire which
# reads the salt. Thus the current behavior of this test should now be identical
# to the previous attach-empty-database-with-default-key -- including for the salt
# comparison, which (per the note above that test) is now expected to differ rather
# than match, since every page's salt is always freshly random on every write.

setup test.db {"x''"}
do_test attach-empty-database-with-default-key-first-op {
  sqlite_orig db test.db
  set rc {}

  execsql {
    PRAGMA  key="x''";
    ATTACH DATABASE 'test2.db' AS test;
    CREATE TABLE test.t1(a,b);
    INSERT INTO test.t1 SELECT * FROM t1;
    DETACH DATABASE test;
  }

  sqlite_orig db2 test2.db

  lappend rc [execsql {
    PRAGMA  key="x''";
    SELECT count(*) FROM t1;
  } db2]

  lappend rc [string equal [hexio_read test.db 0 16] [hexio_read test2.db 0 16]]
} {{ok 1} 0}
db close
db2 close
file delete -force test.db
file delete -force test2.db

# attach an empty encrypted database 
# on a keyed database when PRAGMA cipher_store_pass = 1
# and verify different salts
setup test.db {"x''"}
do_test attach-empty-database-with-cipher-store-pass {
  sqlite_orig db test.db
  set rc {}

  execsql {
    PRAGMA  key="x''";
    PRAGMA cipher_store_pass = 1;
    INSERT INTO t1(a,b) VALUES (1,2);
    ATTACH DATABASE 'test2.db' AS test;
    CREATE TABLE test.t1(a,b);
    INSERT INTO test.t1 SELECT * FROM t1;
    DETACH DATABASE test;
  }

  sqlite_orig db2 test2.db

  lappend rc [execsql {
    PRAGMA  key="x''";
    SELECT count(*) FROM t1;
  } db2]
  lappend rc [string equal [hexio_read test.db 0 16] [hexio_read test2.db 0 16]]
} {{ok 2} 0}
db close
db2 close
file delete -force test.db
file delete -force test2.db

# attach an encrypted database
# without specifying key, verify it attaches
# correctly when PRAGMA cipher_store_pass = 1
# is set
do_test attach-database-with-default-key-using-cipher-store-pass {
    sqlite_orig db1 test.db  
    execsql {
        PRAGMA key = "x''";
        CREATE TABLE t1(a,b);
        INSERT INTO t1(a,b) VALUES('foo', 'bar');        
    } db1
    db1 close

    sqlite_orig db2 test2.db
    execsql {
      PRAGMA key = "x''";
      CREATE TABLE t2(a,b);
      INSERT INTO t2 VALUES ('test1', 'test2'); 
    } db2
    db2 close

    sqlite_orig db1 test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_store_pass = 1;
        ATTACH DATABASE 'test2.db' as db2;
        SELECT sqlcipher_export('db2');
        DETACH DATABASE db2;
    } db1
    db1 close

    sqlite_orig db2 test2.db  
    execsql {
        PRAGMA key = "x''";
        SELECT * FROM t1;
    } db2

} {ok foo bar}
db2 close
file delete -force test.db
file delete -force test2.db

# attach an encrypted database
# where both database have the same
# key explicitly and verify they have different
# salt values
setup test.db {"x''"}
do_test attach-database-with-same-key {
  sqlite_orig db2 test2.db
  
  set rc {}

  execsql {
    PRAGMA key = "x''";
    CREATE TABLE t2(a,b);
    INSERT INTO t2 VALUES ('test1', 'test2'); 
  } db2
 
  lappend rc [execsql {
    SELECT count(*) FROM t2;
    ATTACH 'test.db' AS db KEY "x''";
    SELECT count(*) FROM db.t1;
  } db2]
  
  lappend rc [string equal [hexio_read test.db 0 16] [hexio_read test2.db 0 16]]
} {{1 1} 0}
db2 close
file delete -force test.db
file delete -force test2.db

# attach an encrypted database
# where databases have different keys
setup test.db {"x''"}
do_test attach-database-with-different-keys {
  sqlite_orig db2 test2.db

  execsql {
    PRAGMA key = "x''";
    CREATE TABLE t2(a,b);
    INSERT INTO t2 VALUES ('test1', 'test2'); 
  } db2
  
  execsql {
    ATTACH 'test.db' AS db KEY "x''";
    SELECT count(*) FROM db.t1;
    SELECT count(*) FROM t2;
  } db2

} {1 1}
db2 close
file delete -force test.db
file delete -force test2.db

# test locking across multiple handles
setup test.db {"x''"}
do_test locking-across-multiple-handles-start {
  sqlite_orig db test.db

  execsql {
    PRAGMA key = "x''";
    BEGIN EXCLUSIVE;
    INSERT INTO t1 VALUES(1,2);
  } 
  
  sqlite_orig dba test.db
  catchsql {
    PRAGMA key = "x''";
      SELECT count(*) FROM t1;
  } dba

 } {1 {database is locked}} 

do_test locking-accross-multiple-handles-finish {
 execsql {
    COMMIT;
  }

  execsql {
    SELECT count(*) FROM t1;
  } dba
} {2}
db close
dba close
file delete -force test.db

# alter schema
setup test.db {"x''"}
do_test alter-schema {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    ALTER TABLE t1 ADD COLUMN c;
    INSERT INTO t1 VALUES (1,2,3);
    INSERT INTO t1 VALUES (1,2,4);
    CREATE TABLE t1a (a);
    INSERT INTO t1a VALUES ('teststring');
  }
  db close

  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    SELECT count(*) FROM t1 WHERE a IS NOT NULL;
    SELECT count(*) FROM t1 WHERE c IS NOT NULL;
    SELECT * FROM t1a;
  } 

} {ok 3 2 teststring}
db close
file delete -force test.db

# test alterations of KDF iterations and ciphers
# rekey then add
setup test.db {"x''"}
do_test verify-errors-for-rekey-kdf-and-cipher-changes {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    PRAGMA rekey_kdf_iter = 1000;
    PRAGMA rekey_cipher = 'aes-256-ecb';
  } 
} {ok {PRAGMA rekey_kdf_iter is no longer supported.} {PRAGMA rekey_cipher is no longer supported.}}
db close
file delete -force test.db


setup test.db {"x''"}
do_test verify-errors-for-cipher-change {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher = 'aes-256-ecb';
  } 
} {ok {PRAGMA cipher is no longer supported.}}
db close
file delete -force test.db


# 1. create a database with a custom page size, 
# 2. create table and insert operations should work
# 3. close database, open it again with the same
#    key and page size
# 4. verify that the table is readable
#    and the data just inserted is visible
do_test custom-pagesize-pragma-cipher-page-size {
  sqlite_orig db test.db

  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher_page_size = 8192;
    CREATE table t1(a,b);
    BEGIN;
  }

  for {set i 1} {$i<=1000} {incr i} {
    set r [expr {int(rand()*500000)}]
    execsql "INSERT INTO t1 VALUES($i,'value $r');" 
  }

  execsql {
    COMMIT;
  } 

  db close
  sqlite_orig db test.db

  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher_page_size = 8192;
    SELECT count(*) FROM t1;
  }

} {ok 1000}
db close
file delete -force test.db

# run the same logic as previous test but use
# pragma page_size instead
do_test custom-pagesize-pragma-pagesize {
