#
# This file implements regression tests for SQLite library. The focus of
# this script is testing code cipher features.
#
# NOTE ON THIS FILE (post-leancrypto migration): this file used to test the
# "plaintext header" / "recovery mode" feature (cipher_plaintext_header_size,
# cipher_default_plaintext_header_size, and cipher_salt as a settable,
# database-wide KDF salt), which let part of page 1 be stored genuinely
# unencrypted. That whole feature was intentionally removed in the migration
# to the leancrypto-based Ascon-Keccak-512/HKDF-SHA3-512 codec: every page,
# including page 1, is now always fully encrypted, with no plaintext prefix
# of any kind and no single database-wide salt (every page -- including page
# 1 -- carries its own fresh, independently-random salt in its own reserve
# region). See doc/crypto.md, section "Why there is no on-disk plaintext
# header", for the full rationale (in short: a plaintext carve-out over page
# 1 swallows real, mutable SQLite header state such as the schema cookie and
# user_version, which is an unacceptable correctness regression, and this
# design has no cryptographic bootstrapping problem that would require one
# anyway).
#
# Rather than deleting this file outright, it is kept (a) to verify that
# cipher_plaintext_header_size / cipher_default_plaintext_header_size are
# harmless, clearly-worded deprecated no-ops rather than silently accepted
# or crashing, and (b) to cover cipher_salt's new, narrower meaning: a
# read-only introspection pragma that reports page 1's *current* on-disk
# salt (freshly random on every write, just like every other page's), with
# no way to set it any more.

set testdir [file dirname $argv0]
source $testdir/tester.tcl
source $testdir/sqlcipher.tcl

# verify cipher_plaintext_header_size is a deprecated no-op (get and set)
do_test cipher-plaintext-header-size-is-a-noop {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher_plaintext_header_size;
    PRAGMA cipher_plaintext_header_size = 32;
    CREATE TABLE t1(a,b);
    INSERT INTO t1(a,b) VALUES (1,2);
  }
} {ok {PRAGMA cipher_plaintext_header_size is no longer supported: every page, including page 1, is always fully encrypted.} {PRAGMA cipher_plaintext_header_size is no longer supported: every page, including page 1, is always fully encrypted.}}
db close
file delete -force test.db

# verify cipher_default_plaintext_header_size is a deprecated no-op (get and set)
do_test cipher-default-plaintext-header-size-is-a-noop {
  sqlite_orig db :memory:
  execsql {
    PRAGMA cipher_default_plaintext_header_size;
    PRAGMA cipher_default_plaintext_header_size = 16;
    PRAGMA cipher_default_plaintext_header_size;
  }
} {{PRAGMA cipher_default_plaintext_header_size is no longer supported: every page, including page 1, is always fully encrypted.} {PRAGMA cipher_default_plaintext_header_size is no longer supported: every page, including page 1, is always fully encrypted.} {PRAGMA cipher_default_plaintext_header_size is no longer supported: every page, including page 1, is always fully encrypted.}}
db close

# verify that no plaintext prefix exists any more: the first bytes of an
# encrypted database are never the standard SQLite magic string, regardless
# of any (now inert) plaintext-header setting.
do_test no-plaintext-prefix-even-with-legacy-pragma-set {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher_plaintext_header_size = 16;
    CREATE TABLE t1(a,b);
    INSERT INTO t1(a,b) VALUES (1,2);
  }
  db close
  string equal [hexio_read test.db 0 16] "53514C69746520666F726D6174203300"
} {0}
file delete -force test.db

# verify cipher_salt (get form) returns page 1's real, current on-disk salt
do_test cipher-salt-reports-real-page1-salt {
  sqlite_orig db test.db
  execsql { PRAGMA key = "x''"; }
  set salt [execsql {
    CREATE TABLE t1(a,b);
    PRAGMA cipher_salt;
  }]
  # page 1's reserve region is at the end of the page, not the start, so
  # cipher_salt's value does not need to (and does not) match the first 16
  # file bytes any more -- just confirm it is well-formed (the salt is
  # sized to the provider's internal key size, 64 bytes = 128 hex chars,
  # see doc/crypto.md) and non-zero.
  list [string length $salt] [string equal $salt [string repeat 0 [string length $salt]]]
} {128 0}
db close
file delete -force test.db

# verify cipher_salt is now a deprecated no-op in its setter form
do_test cipher-salt-set-is-a-noop {
  sqlite_orig db test.db
  execsql {
    PRAGMA key = "x''";
    PRAGMA cipher_salt = "x'01010101010101010101010101010101'";
  }
} {ok {PRAGMA cipher_salt can no longer be set: every page's salt, including page 1's, is freshly randomized by the codec on each write.}}
db close
file delete -force test.db

finish_test
