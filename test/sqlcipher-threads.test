#
# This file implements regression tests for SQLite library.  The
# focus of this script is testing code cipher features.
#
# NOTE: tester.tcl has overridden the definition of sqlite3 to
# automatically pass in a key value. Thus tests in this file
# should explicitly close and open db with sqlite_orig in order
# to bypass default key assignment.

set testdir [file dirname $argv0]
source $testdir/tester.tcl
source $testdir/sqlcipher.tcl

# This file is loosely based on threads003.test and is intended to run multiple 
# threaded open / execute / close operations using sqlcipher that can be verified using thread sanitizer. 
# compile a NON-DEBUG build of the testfixture using these flags configure flags: --disable-amalgamation
# and CFLAGS containing -g -sanitize=threads
# run with search -R to disable ASLR
# export TSAN_OPTIONS="verbosity=1 suppressions=sqlcipher-resources/tsan_suppress.txt halt_on_error=0"
# setarch -R ./testfixture test/sqlcipher-threads.test 2>&1 | tee run.log
# grep "SUMMARY.*ThreadSanitizer:" run.log 

# disable serialization of memory operations that could hide warnings
sqlite3_shutdown
sqlite3_config_memstatus 0
sqlite3_initialize

# pre prep a database to be queried
do_test sqlcipher-thread-prep {
  sqlite_orig db :memory:
  execsql {
    PRAGMA cipher_memory_security = ON;
  }
  db close

  sqlite_orig db test.db

  execsql {
    PRAGMA key = "x''";
    CREATE TABLE t1(a,b);
    BEGIN;
  }
  for {set i 1} {$i<=2500} {incr i} {
    execsql "INSERT INTO t1 VALUES($i,randomblob(2000));" 
  }
  execsql {
    COMMIT;
    SELECT count(*) FROM t1;
  } 
} {2500}
db close

# start 10 threads, each one will open the database, query it, and then close it in a loop
# until the timeout expires. Do this for 30 seconds.
set nSecond 30
set nThread 10
puts "Starting sqlcipher-thread-run (should run for ~$nSecond seconds)"
do_test sqlcipher-thread-run {
  for {set i 1} {$i<=$nThread} {incr i} {
    set SCRIPT [format {
      set iEnd [expr {[clock_seconds] + %d}]

      while {[clock_seconds] < $iEnd} {
        set ::DB [sqlthread open %s]
        execsql {
          PRAGMA key = "x''";
          PRAGMA cache_size = 0;
        }
        set iQuery [expr {int(rand()*2500)}]
        execsql "SELECT * FROM t1 WHERE a = $iQuery;"
        sqlite3_close $::DB
      }

      expr 1
    } $nSecond test.db]

    unset -nocomplain finished($i)
    thread_spawn finished($i) $thread_procs $SCRIPT
  }
  for {set ii 1} {$ii<=$nThread} {incr ii} {
    if {![info exists finished($ii)]} {
      vwait finished($ii)
    }
  }
  expr 0
} {0}

file delete -force test.db

set sqlite_open_file_count 0

finish_test
