#
# This file implements regression tests for SQLite library.  The
# focus of this script is testing code cipher features.
#
# NOTE: tester.tcl has overridden the definition of sqlite3 to
# automatically pass in a key value. Thus tests in this file
# should explicitly close and open db with sqlite_orig in order
# to bypass default key assignment.
#
# NOTE ON THIS FILE (post-leancrypto migration): this build has a single,
# fixed algorithm combination (Ascon-Keccak-512 AEAD + HKDF-SHA3-512,
# selected at build time -- see doc/crypto.md) with no PBKDF2/iteration
# count, no separately-toggleable HMAC step (AEAD authentication is
# intrinsic to every page), no runtime HMAC/KDF algorithm selection, and no
# version-compatibility presets. All of the pragmas that used to configure
# those things (cipher_use_hmac, cipher_default_use_hmac, kdf_iter,
# fast_kdf_iter, cipher_default_kdf_iter, rekey_kdf_iter, cipher (setter),
# rekey_cipher, cipher_hmac_salt_mask, cipher_hmac_pgno,
# cipher_hmac_algorithm, cipher_default_hmac_algorithm, cipher_kdf_algorithm,
# cipher_default_kdf_algorithm, cipher_compatibility,
# cipher_default_compatibility) are kept only as harmless, clearly-worded
# deprecation-message no-ops (see the comments above each pragma's handling
# in src/sqlcipher.c) -- this file now verifies that no-op behavior instead
# of the old functional behavior. cipher_page_size, cipher_store_pass, and
# cipher_log_level/cipher_log_source are unrelated to the crypto algorithm
# change and are verified unchanged.

set testdir [file dirname $argv0]
source $testdir/tester.tcl
source $testdir/sqlcipher.tcl

# verify the pragma cipher_version
# returns the currently configured
# sqlcipher version
do_test verify-pragma-cipher-version {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_version;
    }
} {{5.0.0 community}}
db close
file delete -force test.db

# PRAGMA cipher_use_hmac / cipher_default_use_hmac are deprecated no-ops now:
# AEAD authentication is always enabled and cannot be turned off (see
# doc/crypto.md "Known limitations"). Verify the deprecation message is
# returned for both the getter and setter forms.
do_test verify-pragma-cipher-use-hmac-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_use_hmac;
        PRAGMA cipher_use_hmac = off;
        PRAGMA cipher_use_hmac;
    }
} {ok {PRAGMA cipher_use_hmac is no longer supported: AEAD authentication is always enabled.} {PRAGMA cipher_use_hmac is no longer supported: AEAD authentication is always enabled.} {PRAGMA cipher_use_hmac is no longer supported: AEAD authentication is always enabled.}}
db close
file delete -force test.db

do_test verify-pragma-cipher-default-use-hmac-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_default_use_hmac;
        PRAGMA cipher_default_use_hmac = off;
        PRAGMA cipher_default_use_hmac;
    }
} {{PRAGMA cipher_default_use_hmac is no longer supported: AEAD authentication is always enabled.} {PRAGMA cipher_default_use_hmac is no longer supported: AEAD authentication is always enabled.} {PRAGMA cipher_default_use_hmac is no longer supported: AEAD authentication is always enabled.}}
db close
file delete -force test.db

# PRAGMA cipher_default_kdf_iter / kdf_iter / fast_kdf_iter / rekey_kdf_iter are
# deprecated no-ops now: there is no PBKDF2/iteration-count concept for this
# provider (fixed HKDF-SHA3-512, see doc/crypto.md).
do_test verify-pragma-cipher-default-kdf-iter-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_default_kdf_iter;
        PRAGMA cipher_default_kdf_iter = 1000;
        PRAGMA cipher_default_kdf_iter;
    }
} {{PRAGMA cipher_default_kdf_iter is no longer supported.} {PRAGMA cipher_default_kdf_iter is no longer supported.} {PRAGMA cipher_default_kdf_iter is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-kdf-iter-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA kdf_iter;
        PRAGMA kdf_iter = 8000;
        PRAGMA kdf_iter;
    }
} {ok {PRAGMA kdf_iter is no longer supported.} {PRAGMA kdf_iter is no longer supported.} {PRAGMA kdf_iter is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-fast-kdf-iter-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA fast_kdf_iter;
        PRAGMA fast_kdf_iter = 4000;
        PRAGMA fast_kdf_iter;
    }
} {ok {PRAGMA fast_kdf_iter is no longer supported.} {PRAGMA fast_kdf_iter is no longer supported.} {PRAGMA fast_kdf_iter is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-rekey-kdf-iter-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA rekey_kdf_iter = 1000;
    }
} {ok {PRAGMA rekey_kdf_iter is no longer supported.}}
db close
file delete -force test.db

# verify the pragma cipher_page_size
# reports default value
do_test verify-pragma-cipher-page-size-default {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_page_size;
    }
} {ok 4096}
db close
file delete -force test.db

# verify the pragma cipher_page_size
# reports change in value
do_test verify-pragma-cipher-page-size-changed {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_page_size = 8192;
        PRAGMA cipher_page_size;
    }
} {ok 8192}
db close
file delete -force test.db

# verify that a call to pragma page_size
# will report change via both page_size and cipher_page_size
# when there is an attached codec
do_test verify-pragma-page-size-encrypted {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA page_size = 8192;
        PRAGMA page_size;
        PRAGMA cipher_page_size;
    }
} {ok 8192 8192}
db close
file delete -force test.db

# verify that a call to pragma page_size
# will not report a change to cipher_page_size for an
# unencrypted database
do_test verify-pragma-page-size-plaintext {
    sqlite_orig db test.db
    execsql {
        PRAGMA page_size = 8192;
        PRAGMA page_size;
        PRAGMA cipher_page_size;
    }
} {8192}
db close
file delete -force test.db

# verify setting cipher_store_pass before key
# does not cause segfault
do_test verify-cipher-store-pass-before-key-does-not-segfault {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_store_pass = 1;
        PRAGMA key = "x''";
    }
} {ok}
db close
file delete -force test.db

# verify setting cipher_store_pass results in deprecation warning
do_test verify-cipher-store-pass-deprecated {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_store_pass = 1;
    }
} {ok {PRAGMA cipher_store_pass is deprecated, please remove from use}}
db close
file delete -force test.db

# verify the pragma cipher reports the current, real cipher name for this
# single fixed provider (there is exactly one provider now, see
# doc/crypto.md and if_built_with_leancrypto in sqlcipher.tcl)
if_built_with_leancrypto verify-pragma-cipher-default {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher;
    }
} {ok ascon-keccak-512}
db close
file delete -force test.db

# verify that trying to change the cipher via PRAGMA cipher is a
# deprecated no-op (there is exactly one, fixed algorithm combination
# selected at build time -- see doc/crypto.md)
do_test verify-pragma-cipher-set-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher = 'aes-256-ecb';
        PRAGMA cipher;
    }
} {ok {PRAGMA cipher is no longer supported.} ascon-keccak-512}
db close
file delete -force test.db

# PRAGMA cipher_hmac_salt_mask is a deprecated no-op now (the salt itself
# is generated fresh, randomly, per page on every write -- see
# doc/crypto.md -- so there is nothing left to mask).
do_test verify-pragma-hmac-salt-mask-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_hmac_salt_mask;
        PRAGMA cipher_hmac_salt_mask = "x'11'";
        PRAGMA cipher_hmac_salt_mask;
    }
} {ok {PRAGMA cipher_hmac_salt_mask is no longer supported.} {PRAGMA cipher_hmac_salt_mask is no longer supported.} {PRAGMA cipher_hmac_salt_mask is no longer supported.}}
db close
file delete -force test.db

# PRAGMA cipher_hmac_pgno is a deprecated no-op now (the Additional Data
# passed to the AEAD call no longer includes the page number at all -- see
# doc/crypto.md "Known limitations" -- so there is no byte-order concept
# left to configure).
do_test verify-pragma-hmac-pgno-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_hmac_pgno;
        PRAGMA cipher_hmac_pgno = be;
        PRAGMA cipher_hmac_pgno;
    }
} {ok {PRAGMA cipher_hmac_pgno is no longer supported.} {PRAGMA cipher_hmac_pgno is no longer supported.} {PRAGMA cipher_hmac_pgno is no longer supported.}}
db close
file delete -force test.db

# PRAGMA cipher_hmac_algorithm / cipher_default_hmac_algorithm /
# cipher_kdf_algorithm / cipher_default_kdf_algorithm are all deprecated
# no-ops now: there is exactly one fixed algorithm combination
# (Ascon-Keccak-512 AEAD + HKDF-SHA3-512), selected at build time, not at
# runtime (see doc/crypto.md).
do_test verify-pragma-cipher-hmac-algorithm-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_hmac_algorithm;
        PRAGMA cipher_hmac_algorithm = HMAC_SHA1;
        PRAGMA cipher_hmac_algorithm;
    }
} {ok {PRAGMA cipher_hmac_algorithm is no longer supported.} {PRAGMA cipher_hmac_algorithm is no longer supported.} {PRAGMA cipher_hmac_algorithm is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-cipher-default-hmac-algorithm-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_default_hmac_algorithm;
        PRAGMA cipher_default_hmac_algorithm = HMAC_SHA1;
        PRAGMA cipher_default_hmac_algorithm;
    }
} {{PRAGMA cipher_default_hmac_algorithm is no longer supported.} {PRAGMA cipher_default_hmac_algorithm is no longer supported.} {PRAGMA cipher_default_hmac_algorithm is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-cipher-kdf-algorithm-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_kdf_algorithm;
        PRAGMA cipher_kdf_algorithm = PBKDF2_HMAC_SHA1;
        PRAGMA cipher_kdf_algorithm;
    }
} {ok {PRAGMA cipher_kdf_algorithm is no longer supported.} {PRAGMA cipher_kdf_algorithm is no longer supported.} {PRAGMA cipher_kdf_algorithm is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-cipher-default-kdf-algorithm-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_default_kdf_algorithm;
        PRAGMA cipher_default_kdf_algorithm = PBKDF2_HMAC_SHA1;
        PRAGMA cipher_default_kdf_algorithm;
    }
} {{PRAGMA cipher_default_kdf_algorithm is no longer supported.} {PRAGMA cipher_default_kdf_algorithm is no longer supported.} {PRAGMA cipher_default_kdf_algorithm is no longer supported.}}
db close
file delete -force test.db

# PRAGMA cipher_compatibility / cipher_default_compatibility are deprecated
# no-ops now: the per-SQLCipher-version presets they used to select (page
# size, KDF iterations, HMAC/KDF algorithm) don't exist any more -- see
# doc/crypto.md.
do_test verify-pragma-cipher-compatibility-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_compatibility = 1;
    }
} {ok {PRAGMA cipher_compatibility is no longer supported.}}
db close
file delete -force test.db

do_test verify-pragma-cipher-default-compatibility-is-a-noop {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_default_compatibility = 1;
    }
} {{PRAGMA cipher_default_compatibility is no longer supported.}}
db close
file delete -force test.db

# cipher_settings / cipher_default_settings now report only the settings
# that still exist for this provider (page size and the fixed cipher name)
# -- the historic KDF-iteration/HMAC/algorithm lines are gone since those
# concepts no longer exist (see doc/crypto.md).
do_test verify-cipher_settings_default {
    sqlite_orig db test.db
    execsql {
        PRAGMA key = "x''";
        PRAGMA cipher_settings;
    }
} {ok {PRAGMA cipher_page_size = 4096;} {PRAGMA cipher = 'ascon-keccak-512';}}
db close
file delete -force test.db

do_test verify-cipher_default_settings_default {
    sqlite_orig db test.db
    execsql {
        PRAGMA cipher_default_settings;
    }
} {{PRAGMA cipher_default_page_size = 4096;}}
db close
file delete -force test.db

do_test verify-cipher_log_source {
    sqlite_orig db :memory:
    execsql {
        PRAGMA cipher_log_source; -- default should be ANY
        PRAGMA cipher_log_source = NONE; --reset to NONE
        PRAGMA cipher_log_source = PROVIDER; -- add PROVIDER to log source
        PRAGMA cipher_log_source = CORE; -- add CORE to log source
        PRAGMA cipher_log_source = MEMORY; -- add MEMORY to log source
        PRAGMA cipher_log_source = NOTASOURCE; -- stay the same
        PRAGMA cipher_log_source = ANY; -- reset to ANY
    }
} {ANY NONE PROVIDER {CORE PROVIDER} {CORE MEMORY PROVIDER} {CORE MEMORY PROVIDER} ANY}
db close

do_test verify-cipher_log_level {
    sqlite_orig db :memory:
    execsql {
        PRAGMA cipher_log_level; -- default should be WARN
        PRAGMA cipher_log_level = TRACE;
        PRAGMA cipher_log_level = DEBUG;
        PRAGMA cipher_log_level = INFO;
        PRAGMA cipher_log_level = WARN;
        PRAGMA cipher_log_level = ERROR;
        PRAGMA cipher_log_level = NOTALEVEL; -- an unknown level should set back to none
    }
} {WARN TRACE DEBUG INFO WARN ERROR NONE}
db close

finish_test
